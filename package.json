{
  "name": "managed-agents-poc",
  "version": "1.0.0",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "server": "ts-node src/server.ts",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,magenta \"npm run server\" \"npm run client\"",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "npm --prefix client run build",
    "build": "npm run build:server && npm run build:client",
    "start": "NODE_ENV=production node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "seed:demos": "ts-node --transpile-only src/scripts/seedDemoWorkflows.ts",
    "postinstall": "prisma generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Bare-bones proof of concept for Claude managed agents",
  "private": "true",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^25.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "jsforce": "^3.10.14",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prisma": "^6.19.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
