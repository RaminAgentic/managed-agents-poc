        },
        {
          "id": "4ea932d8-0a70-4419-8b26-2ea0cd311ec4",
          "title": "Create hardcoded sample prompts and system instructions",
          "description": "Create `src/data/prompts.ts` exporting a `SYSTEM_PROMPT` constant (brief instructions for a helpful assistant that can use tools) and a `SAMPLE_USER_PROMPTS` array with 2-3 example prompts suitable for demoing the managed agent (e.g., weather lookup, simple calculation). Export typed constants only — no runtime logic.",
          "purpose": "Provides deterministic, reusable prompt content so the Sprint 2 CLI can demo the agent without requiring user input for every run.",
          "functionality": "Static prompt data module supplying system and user prompts to the agent loop.",
          "successCriteria": [
            "`SYSTEM_PROMPT` is exported as a non-empty string constant",
            "`SAMPLE_USER_PROMPTS` contains at least 2 entries",
            "Module has no runtime side effects on import",
            "Types are explicitly declared (e.g., `readonly string[]`)"
          ],
          "status": "completed",
          "priority": "high",
          "relevantFiles": [
            {
              "path": "src/data/prompts.ts",
              "action": "create"
            }
          ]
        },
        {
          "id": "d8d2b34a-8055-4be9-a344-e81bc38011f0",
          "title": "Define sample tool schemas for the managed agent",
          "description": "Create `src/data/tools.ts` exporting a `TOOLS` array conforming to the Anthropic SDK `Tool` type, containing one example tool definition (e.g., `get_weather` with `location` string input) following the quickstart format. Also create `src/data/toolHandlers.ts` with a stubbed handler map that returns hardcoded mock results keyed by tool name. Do not implement real external API calls.",
          "purpose": "Supplies the tool definitions and mock handlers that Sprint 2's agent loop will pass to the Anthropic API and invoke on tool_use blocks.",
          "functionality": "Static tool schema definitions plus a lookup of stub handler functions returning canned responses.",
          "successCriteria": [
            "`TOOLS` array contains at least one tool with `name`, `description`, and `input_schema`",
            "Tool `input_schema` is a valid JSON Schema object",
            "`toolHandlers.ts` exports a handler map keyed by tool name returning stringified mock results",
            "Handler for the defined tool returns deterministic output when called"
          ],
          "status": "completed",
          "priority": "high",
          "relevantFiles": [
            {
              "path": "src/data/tools.ts",
              "action": "create"
            },
            {
              "path": "src/data/toolHandlers.ts",
              "action": "create"
            }
          ]
        },
        {
          "id": "c92e31b3-d198-4d3f-af05-0235f41630da",
          "title": "Implement conversation state module",
          "description": "Create `src/data/conversationState.ts` exporting a `ConversationState` class (or factory) that maintains an in-memory array of `MessageParam` objects. Expose `addUserMessage(text)`, `addAssistantMessage(content)`, `addToolResult(toolUseId, result)`, `getMessages()`, and `reset()` methods. Use types from `@anthropic-ai/sdk` so messages plug directly into `client.messages.create`.",
          "purpose": "Provides the message history buffer the Sprint 2 agent loop mutates across turns to support multi-turn tool_use → tool_result cycles.",
          "functionality": "In-memory conversation log that accumulates user, assistant, and tool-result messages in the shape required by the Messages API.",
          "successCriteria": [
            "`ConversationState` exposes add/get/reset methods",
            "`getMessages()` returns an array typed as `MessageParam[]` from the Anthropic SDK",
            "`addToolResult` produces a user message with a `tool_result` content block referencing the given `tool_use_id`",
            "`reset()` clears the internal message array"
          ],
          "status": "completed",
          "priority": "high",
          "relevantFiles": [
            {
              "path": "src/data/conversationState.ts",
              "action": "create"
            },
            {
              "path": "package.json",
              "action": "read"
            }
          ]
        }
