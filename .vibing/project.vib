    {
      "id": "sprint_1776848975734_pof4ndyfo",
      "name": "Sprint 4: Convert CLI to Web App",
      "description": "Replace the CLI entrypoint with an Express web server serving a chat-style browser UI on port 5002. Users interact with the orchestrator through a web page instead of the terminal. Keep all existing agent logic (orchestrator, weather agent, research agent) intact — only change the I/O layer from CLI to HTTP/HTML.",
      "priority": "high",
      "status": "completed",
      "individualTasks": [
        {
          "id": "task_1776848975739_0_tebzg",
          "title": "Add Express server with API endpoint",
          "description": "Install express and @types/express. Create src/server.ts as the new entrypoint: an Express app on port 5002 with a POST /api/chat endpoint that accepts {prompt: string}, calls runOrchestrator(prompt), and returns {response: string} as JSON. Add a GET / route that serves the static HTML frontend. Update package.json scripts so 'dev' and 'start' launch the server instead of the CLI.",
          "status": "completed",
          "priority": "high"
        },
        {
          "id": "task_1776848975739_1_lcvhv",
          "title": "Create browser chat UI",
          "description": "Create a public/index.html with a simple but clean chat interface: a message display area, a text input, and a send button. Use inline CSS for a modern dark-themed chat layout. JavaScript fetches POST /api/chat with the user's prompt and displays the response. Show a loading indicator while waiting for the agent response. No framework needed — vanilla HTML/CSS/JS.",
          "status": "completed",
          "priority": "high"
        },
        {
          "id": "task_1776848975739_2_61jlv",
          "title": "Add sample prompt buttons to the UI",
          "description": "Add clickable sample prompt buttons above the input (e.g. 'Weather in SF', 'Explain managed agents', 'Weather in Paris') so users can quickly test both routing paths without typing. Clicking a button populates and submits the prompt automatically.",
          "status": "completed",
          "priority": "medium"
        },
        {
          "id": "task_1776848975739_3_18v9i",
          "title": "Add agent routing indicator to responses",
          "description": "Modify the /api/chat response to include which agent handled the request (weather-agent or research-agent) alongside the response text. Display this routing info as a subtle label above each response in the chat UI so users can see the orchestrator's classification in action.",
          "status": "completed",
          "priority": "medium"
        }
      ]
    },
    {
      "id": "sprint_1776848977352_jcdscsrps",
      "name": "Sprint 4: Web App UI",
      "description": "Convert the CLI POC into a proper web app. Add an Express server that exposes the orchestrator as a REST API, and build a React + MUI chat interface on the frontend so users can type prompts and see agent responses in the browser at port 5002.",
      "priority": "high",
      "status": "completed",
      "individualTasks": [
        {
          "id": "task_1776848977370_0_qags8",
          "title": "Add Express API server with /api/chat endpoint",
          "description": "Install express and cors. Create src/server.ts that imports runOrchestrator and exposes POST /api/chat accepting { prompt: string } and returning { response: string }. The server should listen on port 5002. Add a 'server' script to package.json that runs this with ts-node.",
          "status": "completed",
