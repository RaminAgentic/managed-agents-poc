              "action": "read"
            },
            {
              "path": "src/data/conversationState.ts",
              "action": "read"
            },
            {
              "path": "src/agent/toolDispatcher.ts",
              "action": "read"
            }
          ]
        },
        {
          "id": "6690d394-c4e2-4ef9-9cc5-973c42dfe7c3",
          "title": "Create CLI entrypoint accepting a user prompt",
          "description": "Create `src/index.ts` as the CLI entrypoint. Read the user prompt from `process.argv.slice(2).join(' ')`; if empty, fall back to the first entry in `SAMPLE_USER_PROMPTS`. Call `runAgent(prompt)` and print the returned response to stdout with `console.log`. Wire `package.json` `start` and `dev` scripts to invoke this file.",
          "purpose": "Exposes the agent loop through a minimal command-line interface so the POC can be demonstrated with a single `npm run dev` invocation.",
          "functionality": "Parses a prompt from CLI args (or uses a sample fallback), runs the managed agent, and prints the final response.",
          "successCriteria": [
