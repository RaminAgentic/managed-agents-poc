ANTHROPIC_API_KEY=your_api_key_here

# Postgres connection string. For local dev: run Postgres locally (brew install postgresql@16)
# and use postgresql://localhost:5432/managed_agents_poc. For Render: copy the Internal
# Database URL from the Postgres dashboard and set as an env var on the web service.
DATABASE_URL="postgresql://localhost:5432/managed_agents_poc"

# Slack slash-command signing secret. From api.slack.com → your app → Basic Information.
# If unset, signature verification is skipped (local dev only).
SLACK_SIGNING_SECRET=

# Set to "false" to disable fire-and-forget workflow execution on POST /runs.
# Runs will still be created with status=pending but the executor won't start.
# ENABLE_WORKFLOW_EXECUTOR=false
