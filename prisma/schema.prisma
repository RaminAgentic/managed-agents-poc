// Prisma schema for Managed Agents POC — workflow execution tracking
//
// All workflow definitions, run instances, step executions, events,
// and approval records are stored in a local SQLite database.
//
// ── Sprint 7 Column Audit ────────────────────────────────────────────
// Spec required 5 tables via raw better-sqlite3 + CREATE TABLE IF NOT EXISTS.
// Decision: Prisma + managed migrations is strictly more capable and was
// already in place from Sprint 6. All spec-required columns are present:
//   workflows:     id, name, schema_json, version, created_at  ✓  (+ updated_at)
//   workflow_runs: id, workflow_id, status, input_json, created_at, completed_at  ✓  (+ started_at)
//   run_steps:     id, run_id, node_id, status, input_json, output_json,
//                  agent_session_id, started_at, completed_at  ✓  (+ error_message, error_stack)
//   run_events:    id, run_id, step_id, event_type, payload, created_at  ✓
//   approvals:     id, step_id, slack_channel, slack_user_id, decision, comment, created_at  ✓
//
// DB file: data/workflow.db (spec said workbench.db — kept as workflow.db
// to preserve migration history; renaming would orphan the applied migration).
// ─────────────────────────────────────────────────────────────────────

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Workflow definition — the blueprint for a run.
model Workflow {
  id        String   @id @default(cuid())
  name      String
  schemaJson String  @map("schema_json")
  version   Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")
  runs      WorkflowRun[]

  @@map("workflows")
}

/// A single execution of a workflow.
model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String    @map("workflow_id")
  workflow    Workflow   @relation(fields: [workflowId], references: [id])
  status      String    @default("pending") // pending | running | completed | failed
  inputJson   String    @default("{}") @map("input_json")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  steps       RunStep[]
  events      RunEvent[]

  @@index([workflowId])
  @@map("workflow_runs")
}

/// An individual step execution within a run.
model RunStep {
  id             String    @id @default(cuid())
  runId          String    @map("run_id")
  run            WorkflowRun @relation(fields: [runId], references: [id])
  nodeId         String    @map("node_id")
  status         String    @default("running") // running | completed | failed | awaiting_approval
  inputJson      String?   @map("input_json")
  outputJson     String?   @map("output_json")
  errorMessage   String?   @map("error_message")
  errorStack     String?   @map("error_stack")
  agentSessionId String?   @map("agent_session_id")
  startedAt      DateTime  @default(now()) @map("started_at")
  completedAt    DateTime? @map("completed_at")
  approvals      Approval[]

  @@index([runId])
  @@map("run_steps")
}

/// Event log entry (audit trail) for a workflow run.
model RunEvent {
  id        String   @id @default(cuid())
  runId     String   @map("run_id")
  run       WorkflowRun @relation(fields: [runId], references: [id])
  stepId    String?  @map("step_id")
  eventType String   @map("event_type")
  payload   String   @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@map("run_events")
}

/// Approval record for human-gate steps.
model Approval {
  id           String   @id @default(cuid())
  stepId       String   @map("step_id")
  step         RunStep  @relation(fields: [stepId], references: [id])
  slackChannel String?  @map("slack_channel")
  slackUserId  String?  @map("slack_user_id")
  decision     String?  // pending | approved | rejected
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("approvals")
}
